@using BatDongSan.Models.PhieuDeNghi;
@model PhieuDanhGiaNVPBModel
@{
    ViewBag.Title = "Đăng ký phiếu đánh giá nhân viên phòng ban";
    Layout = "~/Views/Shared/_Layout.cshtml";
    List<BatDongSan.Models.NhanSu.NhanVienModel> nhanVienThuocNhoms = ViewBag.ChiTietNhanVien;
    var listNV = ViewBag.ListChiTiet as List<PhieuDanhGiaChiTiet>;
}
<link rel="stylesheet" href="~/Content/summernote/summernote.css" />
<script src="~/Content/summernote/summernote.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/additional-methods.min.js"></script>
<script src="~/Scripts/autoNumeric.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>
<script src="~/Scripts/moment.min.js"></script>
<script src="~/Scripts/vi.js"></script>
<script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>
<link rel="stylesheet" href="~/Content/bootstrap-datetimepicker.min.css" />
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>

<script>
    $(document).ready(function () {
        setEvent();
        $("#btnTroVe").click(function () {
            var url = "@Url.Action("Index")";
            location.href = url;
        });
        $('#editor').summernote({
            height: 150,                 // set editor height
            minHeight: null,             // set minimum height of editor
            maxHeight: null             // set maximum height of editor
            //focus: true                  // set focus to editable area after initializing summernote
        });
        $(".timepicker").datetimepicker({
            locale: 'vi',
            format: 'HH:mm'
        });

        $(".datepicker").datetimepicker({
            locale: 'vi',
            format: 'DD/MM/YYYY',
            useCurrent: false
        });
        $("#btnSubmit").click(function () {
            if (CheckForm()) {
                $("#form-submit").submit();
            }
        });


        $('#btnNhanVien').click(function () {
            var url = '@Url.Action("DanhSachNhanVien", "PhieuDanhGiaNhanVienPhongBan")';
            showPopup(url, 980, 550);
        });

        $(document).on("click", ".btnXoa", function () {
            $(this).closest("tr").remove();
        });

        $(".btnXacNhanKeHoach").click(function () {
            bootbox.confirm("Sau khi Anh Chị xác nhận, kế hoạch làm việc sẽ được gởi đến từng nhân viên trong phòng!", function (result) {
                if (result) {
                    var url = '@Url.Action("XacNhanKeHoachDenNVPB", "PhieuDanhGiaNhanVienPhongBan")' + '/' + $("#MaPhieu").val();
                    $.ajax({
                        url: url,
                        type: 'POST',
                        data: 'json',
                        success: function () {
                            Alert.success("Kế hoạch làm việc sẽ được gởi đến từng nhân viên trong phòng thành công", "Thông báo", { displayDuration: 2000 });
                            window.location.reload();
                        },
                        error: function () {
                            Alert.success("Kế hoạch làm việc sẽ được gởi đến từng nhân viên trong phòng thất bại", "Thông báo", { displayDuration: 2000 });
                            //$(".pageLoading").hide();
                        }
                    })


                }
            });
        });


        $(".btnXacNhan").click(function () {
            bootbox.confirm("Bạn chắc chắn gửi phiếu đánh giá nhân viên đến phòng hành chính nhân sự", function (result) {
                if (result) {
                    var url = '@Url.Action("XacNhanGuiDenHSNS", "PhieuDanhGiaNhanVienPhongBan")' + '/' + $("#MaPhieu").val();
                    $.ajax({
                        url: url,
                        type: 'POST',
                        data: 'json',
                        success: function () {
                            Alert.success("Gửi phiếu đánh giá nhân viên đến phòng hành chính nhân sự thành công", "Thông báo", { displayDuration: 2000 });
                            window.location.reload();
                        },
                        error: function () {
                            Alert.success("Gửi phiếu đánh giá nhân viên đến phòng hành chính nhân sự thất bại", "Thông báo", { displayDuration: 2000 });
                            //$(".pageLoading").hide();
                        }
                    })


                }
            });
        });


    });

    function beginPaging(args) {
        // Animate         
        $('#content').fadeOut('fast');
    }

    function successPaging() {
        // Animate        
        $('#content').fadeIn('fast');
    }


    function CheckForm() {
        var flag = true;
        if ($("#TuNgay").val() == "") {
            $("#TuNgay").addClass("error").attr("title", "Xin vui lòng chọn ngày bắt đầu");
            flag = false;
        }

        if ($("#DenNgay").val() == "") {
            $("#DenNgay").addClass("error").attr("title", "Xin vui lòng chọn ngày kết thúc");
            flag = false;
        }

        if (flag == true) {
            var ngayBD = $('#TuNgay').val();
            var ngayKT = $('#DenNgay').val();
            var d1 = Date.parse(convertDate(ngayBD));
            var d2 = Date.parse(convertDate(ngayKT));
            if (d1 > d2) {
                flag = false;
                Alert.error("Ngày bắt đầu  lớn hơn ngày kết thúc. Vui lòng nhập lại.", "Thông báo", { displayDuration: 3000 });
                $("#TuNgay").val("");
                $("#TuNgay").addClass("error").attr("title", "Xin vui lòng chọn ngày bắt đầu");
            }
        }


        if ($("#NoiDung").val() == "") {
            $("#NoiDung").addClass("error").attr("title", "Vui lòng nhập lý do.");
            flag = false;

        }
        return flag;
    }

    function enterToSeacrh(event) {
        if (event.keyCode == 13)
            $("#btnSearch").click();
    }

    function DeleteRow(id_tbody, index, sTT) {
        var table = document.getElementById(id_tbody);
        var maNCC = $('#' + id_tbody + ' tr:eq(' + index + ')').find("a").html();
        var tenNCC = $('#' + id_tbody + ' tr:eq(' + index + ')').find("td:eq(" + 2 + ")").html();

        table.deleteRow(index);

        for (var i = 0; i < table.rows.length; i++) {
            if (sTT == null)
                $('#' + id_tbody + ' tr:eq(' + i + ')').find("td:last").html("<a href='javascript:void(0);' onclick='DeleteRow(\"" + id_tbody + "\"," + i + ")'>Xóa</a>");
            else {
                $('#' + id_tbody + ' tr:eq(' + i + ')').find("td:first").html(i + 1);
                $('#' + id_tbody + ' tr:eq(' + i + ')').find("td:last").html("<a href='javascript:void(0);' onclick='DeleteRow(\"" + id_tbody + "\"," + i + ", true)'>Xóa</a>");
            }
        }
    }

    function setEvent() {
        $(".numberinput").autoNumeric('init', { mDec: 0, mNum: 3, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0' });
        $(".numberinputInt").autoNumeric('init', { lZero: 'deny', mDec: 0, pSign: 's', aSep: ',', aDec: '.' });
        $('textarea').keydown(function (event) {
            if (event.keyCode == 13) {
                event.preventDefault();
                var s = $(this).val();
                $(this).val(s + "\n");
            }
        });
    }

</script>
<style>
    #tbl-create td {
        border: none;
    }

    .numberinput {
        text-align: right;
    }
</style>
<form id="form-submit" class="form-horizontal" method="post">
    <div id="container" class="custome_fieldSet">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="width: 30%; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                        <a><span><i class="fa fa-plus-square-o" aria-hidden="true"></i>Thêm mới phiếu đánh giá</span></a></li>
                </ul>
            </div>
            <table class="table table-striped table-hover table-condensed TableMobileChild" id="tbl-create" style="position: relative">
                <tr>
                    <td style="width: 15%" class="tdtitle">Mã phiếu</td>
                    <td style="width: 35%">@Html.TextBoxFor(model => model.MaPhieu, new { @class = "form-control", @readonly = true })</td>
                    <td style="width: 15%" class="tdtitle">Ngày lập</td>
                    <td style="width: 35%">@Html.TextBoxFor(model => model.NgayLap, "{0: dd/MM/yyyy}", new { @class = "form-control", @readonly = true })</td>
                </tr>
                <tr>
                    <td style="width: 15%" class="tdtitle">Mã nhân viên</td>
                    <td style="width: 35%">@Html.TextBoxFor(model => model.MaNhanVienLP, new { @class = "form-control", @readonly = true })</td>
                    <td style="width: 15%" class="tdtitle">Tên nhân viên </td>
                    <td style="width: 35%">@Html.TextBoxFor(model => model.HoTenNVLP, new { @class = "form-control", @readonly = true })</td>
                </tr>
                <tr>
                    <td class="tdtitle">Từ ngày</td>
                    <td>@Html.TextBoxFor(model => model.TuNgay, "{0: dd/MM/yyyy}", new { @class = "form-control datepicker" })</td>
                    <td class="tdtitle">Đến ngày</td>
                    <td>@Html.TextBoxFor(model => model.DenNgay, "{0: dd/MM/yyyy}", new { @class = "form-control datepicker" })</td>
                </tr>
                <tr>
                    <td class="tdtitle">Nội dung</td>
                    <td colspan="3">
                        @Html.TextAreaFor(model => model.NoiDung, new { @class = "form-control" })
                    </td>
                </tr>
            </table>
            <br />
            <label>
                <button class="btn btn-link btn-sm" id="btnNhanVien" type="button">Thêm nhân viên</button>
            </label>
            <div id="containerNhanVien">
                <table class="table table-striped table-hover table-condensed  TableMobile IndexNhanVienPNP" id="tbl-users">
                    <thead>
                        <tr id="trtop">
                            <th>STT</th>
                            <th>Họ và tên</th>
                            <th>Phòng ban</th>
                            <th>Kế hoạch làm việc</th>
                            <th style="width: 100px">Tỷ lệ hoàn thành (%)</th>
                            <th style="width: 300px">Ghi chú</th>
                            <th style="width: 40px"></th>
                        </tr>
                    </thead>
                    <tbody id="tbody">
                        @if (listNV != null && listNV.Count > 0)
                        {
                            int i = 1;
                            foreach (var item in listNV)
                            {
                            <tr>
                                <td class="sothutu" style="text-align: center">@i</td>
                                <td>
                                    <i class="fa fa-user" aria-hidden="true" style="color: #519ee5"></i>&nbsp;@item.HoTenNV
                                </td>
                                <td>@item.TenPhongBan</td>
                                <td>
                                    @Html.TextArea("KeHoachLamViecTaiNha", item.KeHoachLamViecTaiNha, new { @class = "form-control" })
                                    <input type="hidden" id="maNhanVien" name="maNhanVien" value="@item.MaNhanVien"/>
                                </td>
                                <td style="text-align: right">
                                    @Html.TextBox("TyLeHoanThanh", item.TyLeHoanThanh, new { @class = "form-control numberinput" })
                                </td>
                                <td>
                                    @Html.TextBox("GhiChu", item.GhiChu, new { @class = "form-control" })
                                </td>
                                <td style="text-align: center">
                                    <a href="javascript:void(0);" onclick="DeleteRow('tbody',@(i - 1),'true');"
                                        style="color: Blue">Xóa</a>
                                </td>
                            </tr> 
                                i++;
                            }
                        }
                    </tbody>
                </table>
            </div>
            <br />
            <div style="text-align: right; margin-bottom: 10px">
                @{
                    BatDongSan.Models.HeThong.Sys_User user1 = new BatDongSan.Models.HeThong.Sys_User();
                    if (Session["User"] != null)
                    {
                        user1 = (BatDongSan.Models.HeThong.Sys_User)Session["User"];
                    }
                }
                @if ((user1.manv == Model.MaNhanVienLP) && Model.XacNhan != 1)
                {
                    if (Model.XacNhan == 0)
                    {
                    <button class="btn btn-info btnXacNhanKeHoach" type="button">Xác nhận kế hoạch làm việc </button>
                    }
                    else if (Model.XacNhan == 2)
                    {
                    <button class="btn btn-info btnXacNhan" type="button">Gửi </button>
                    }
                    <button class="btn btn-info" id="btnSubmit" type="button">Lưu </button>
                  
                }
                <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
            </div>
        </fieldset>
    </div>
</form>

<div id="myModal" class="modal fade" role="dialog">
    <div class="modal-dialog" style="width: 900px">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-body">
                <div class="container" style="width: 98%">
                    <div class="row">
                        <div style="position: relative">
                            <input type="text" id="searchString" class="form-control" style="padding-right: 30px; border-radius: 50px" placeholder="Search" onkeyup="enterToSeacrh(event)">
                            <i class="fa fa-search" id="btnSearch" style="position: absolute; cursor: pointer; top: 6px; right: 7px;"></i>
                        </div>
                        <div id="filter-panel" class="filter-panel" style="padding-top: 10px;">
                            <div class="panel panel-default" style="border: none">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary btn-sm" id="btnAccept">
                    <span class="glyphicon glyphicon-ok"></span>&nbsp;Đồng ý
                </button>
                <button type="button" class="btn btn-default" data-dismiss="modal" id="btnClose">Hủy</button>
            </div>
        </div>
    </div>
</div>


<div id="myModalChonPhongBan" class="modal fade" role="dialog">
    <div class="modal-dialog modal-lg">
        <!-- Modal content-->
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title"></h4>
            </div>
            <div class="modal-body">
                <div class="container" style="width: 98%">
                    <div class="row">
                        <div id="filter-panelNV" class="filter-panel">
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
            </div>
        </div>

    </div>
</div>

