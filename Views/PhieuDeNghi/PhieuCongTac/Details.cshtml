@using BatDongSan.Models.PhieuDeNghi;
@model PhieuDeNghiCongTac
@{
    ViewBag.Title = "Chi tiết phiếu đăng ký công tác";
    Layout = "~/Views/Shared/_Layout.cshtml";
    string[] nhanVienNS = ViewBag.NhanVienThuocNhoms;
}

<script>
    $(document).ready(function () {
        $("#btnTroVe").click(function () {
            var url = "@Url.Action("Index")";
            location.href = url;
        });
    });

    function PopUpManager(url, title, w, h) {
        var left = (screen.width / 2) - (w / 2);
        var top = (screen.height / 2) - (h / 2);
        var targetWin = window.open(url, title, 'width=' + w + ', height=' + h + ', top=' + top + ', left=' + left);
    }
    function chonNguoiDuyet(status, employeeId) {
        if ($("#NhanVien_maNhanVien").val() != $("#maNVD").val()) {
            $("#maNVD").val($("#NhanVien_maNhanVien").val());
        }
        var lyDo = "";
        var url = ('@Url.Action("SelectCapDuyet1/", "DMNguoiDuyet")' + $('#maPhieu').val() + '?maCongViec=PhieuCongTac' + '&trangThai=' + 0 + '&title=' + "" + '&maNhanVien=' + $("#maNVD").val() + '&lyDo=' + lyDo + "&idQuiTrinh=" + $("#maQuiTrinhDuyet").val() + '&url=' + $("#url").val());
        PopUpManager(url, "DUYET", 800, 500);
    }

    function chonNguoiDuyet2(status, employeeId) {
        var lyDo = '';
        var url = ('@Url.Action("SelectCapDuyet/", "DMNguoiDuyet")' + $('#maPhieu').val() + '?maCongViec=PhieuCongTac' + '&trangThai=' + 0 + '&title=' + "" + '&maNhanVien=' + $("#maNVD").val() + '&lyDo=' + lyDo + "&idQuiTrinh=" + $("#maQuiTrinhDuyet").val() + '&url=' + $("#url").val());
        PopUpManager(url, "DUYET", 800, 500);
    }

    function DuyetPhieu() {
        var url = ('@Url.Action("DuyetPhieuDK/", "DMNguoiDuyet")' + $('#maPhieu').val() + '?maCongViec=PhieuCongTac' + '&maQuiTrinhDuyet=' + $('#maQuiTrinhDuyet').val() + '&url=' + $('#url').val() + '&maNhanVien=' + $('#maNVD').val());
        PopUpManager(url, "DUYET", 1000, 300);
      @*  if (window.confirm('Bạn có chắc chắn duyệt phiếu công tác này hay không?')) {
            var lyDo = "";//$('#lyDo').val().replace(/\ /g, '+');
            $.post('@Url.Action("DuyeTheoQuiTrinhDong", "DMNguoiDuyet")', { lyDo: lyDo, maNhanVien: $('#maNVD').val(), maPhieu: $('#maPhieu').val(), soNgayNghiPhep: $('#soNgayNghiPhep').val(), maCongViec: "PhieuCongTac", tenNhanVien: $('#tenNhanVien').val(), idQuiTrinh: $("#maQuiTrinhDuyet").val(), sendMail: false, sendSMS: false }, function (data) {
                if (data.length == 0) {
                    location.href = '@Url.Action("Details/", "PhieuCongTac")' + $('#maPhieu').val();
                }
                else {
                    jAlert(data);
                }
            });
        }*@
    }

    function LoadLaiTrang() {
        location.href = '@Url.Action("ListCongViecProcess", "User")';
    }

    function LoadLaiTrangChiTiet() {
        location.href = '@Url.Action("Details/", "PhieuCongTac")' + $('#maPhieu').val();
    }

    function KhongDuyet() {

        if (window.confirm('Bạn có chắc chắn không duyệt phiếu công tác này hay không?')) {
            var lyDo = "";
            //$('#lyDo').val().replace(/\ /g, ' ');
            $.post('@Url.Action("TraLaiNew", "DMNguoiDuyet")', { lyDo: lyDo, maNhanVien: $('#maNV').val(), maPhieu: $('#maPhieu').val(), soNgayNghiPhep: $('#soNgayNghiPhep').val(), maCongViec: "PhieuCongTac", tenNhanVien: $('#tenNhanVien').val(), idQuiTrinh: $("#maQuiTrinhDuyet").val(), sendMail: false, sendSMS: false }, function (data) {
                if (data.length == 0) {
                    location.href = '@Url.Action("Details/", "PhieuCongTac")' + $('#maPhieu').val();
                }
                else {
                    jAlert(data);
                    //$(this).attr("disabled", false);
                }
            });
        }
    }

    function TraLai(status, employeeId) {
        var url = ('@Url.Action("TraLai/", "DMNguoiDuyet")' + $('#maPhieu').val() + '?maCongViec=PhieuCongTac' + '&trangThai=' + 0 + '&title=' + "" + '&maNhanVien=' + $("#maNVD").val() + '&lyDo=' + "" + "&idQuiTrinh=" + $("#maQuiTrinhDuyet").val() + '&url=' + $("#url").val());
        PopUpManager(url, "DUYET", 700, 200);
    }
</script>
<style>
    #tbl-create td
    {
        border: none;
    }
</style>
@{
    string noiCongTac = string.Empty;
    string loaiCongTac = string.Empty;
    //if (Model.loaiCongTac == false)
    //{
    //    noiCongTac = Model.tenTinh;
    //    loaiCongTac = "Trong nước";
    //}
    //else if (Model.loaiCongTac == true)
    //{
    //    noiCongTac = Model.tenQuocGia;
    //    loaiCongTac = "Nước ngoài";
    //}

    BatDongSan.Models.HeThong.Sys_User user1 = new BatDongSan.Models.HeThong.Sys_User();
    if (Session["User"] != null)
    {
        user1 = (BatDongSan.Models.HeThong.Sys_User)Session["User"];
    }  
    
}
<div id="container" class="custome_fieldSet">
    <fieldset class="removeBorderFieldset">
        <div id="tabs" style="width: 30%; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
            <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                    <a><span><i class="fa fa-yelp" aria-hidden="true"></i>Cập nhật phiếu công tác</span></a></li>
            </ul>
        </div>
        <table class="table table-striped table-hover table-condensed TableMobileChild" id="tbl-create" style="position: relative">
            @if (Model.NhanVien.maNhanVien != Model.NhanVienLapPhieuTT.maNhanVien)
            {
                <tr>
                    <td style="width: 15%" class="tdtitle">MNV lập phiếu TT                                                                   
                    </td>
                    <td style="width: 35%">@Model.NhanVienLapPhieuTT.maNhanVien</td>
                    <td style="width: 15%" class="tdtitle">Họ tên NV lập phiếu TT </td>
                    <td style="width: 35%">@Model.NhanVienLapPhieuTT.hoVaTen</td>
                </tr>
            }
            <tr>
                <td style="width: 15%" class="tdtitle">Mã nhân viên công tác</td>
                <td style="width: 35%">@Model.NhanVien.maNhanVien
                    @Html.HiddenFor(model => model.NhanVien.maNhanVien)
                    <input type="hidden" id="url" value="@ViewBag.URL" />
                    @Html.HiddenFor(model => model.maQuiTrinhDuyet)
                </td>
                <td style="width: 15%" class="tdtitle">Tên nhân viên công tác</td>
                <td style="width: 35%">@Model.NhanVien.hoVaTen</td>
            </tr>
            <tr>
                <td class="tdtitle">Số phiếu ĐK công tác </td>
                <td>@Model.maPhieu
                </td>
                @*<td>Loại công tác</td>
                <td>
                    @loaiCongTac
                </td>*@
                <td class="tdtitle">Phòng ban công tác </td>
                <td>@Model.tenPhongBan
                </td>
            </tr>
            <tr>
                <td class="tdtitle">Ngày bắt đầu</td>
                <td>@String.Format("{0: dd/MM/yyyy}", Model.ngayBatDau)</td>
                <td class="tdtitle">Ngày kết thúc</td>
                <td>@String.Format("{0: dd/MM/yyyy}", Model.ngayKetThuc)</td>
            </tr>
            <tr>
                <td class="tdtitle">Giờ bắt đầu</td>
                <td>@String.Format("{0:HH\\:mm}", Model.gioBatDau)</td>
                <td class="tdtitle">Giờ kết thúc</td>
                <td>@String.Format("{0:HH\\:mm}", Model.gioKetThuc)</td>
            </tr>
            <tr>
                <td class="tdtitle">Số ngày công tác</td>
                <td>@Model.soNgayCongTac</td>
                @*<td>Nơi công tác</td>
                <td>
                    @noiCongTac
                </td>*@
                <td class="tdtitle">Phụ cấp công tác</td>
                <td>@String.Format("{0: #,#0}", Model.phuCap)</td>
            </tr>
            <tr>
                <td class="tdtitle">Ghi chú</td>
                <td colspan="3">@Html.Raw(Model.ghiChu)</td>

            </tr>
        </table>
        <div style="text-align: right; margin-bottom: 10px">
            <input type="hidden" name="maNVD" id="maNVD" value="@user1.manv" />
            <input type="hidden" name="tenNhanVien" id="tenNhanVien" value="@ViewBag.HoTen" />
            @Html.HiddenFor(model => model.maPhieu)
            @Html.HiddenFor(model => model.lyDo)
            @if (ViewBag.TenTrangThaiDuyet != "KDD")
            {
                if ((Model.Duyet == null || Model.Duyet.tinhTrang == 0) && Model.nguoiLap == user1.manv && Model.Duyet.maBuocDuyet != "KDD")
                {
                <button class="btn btn-info" type="button" onclick="chonNguoiDuyet();">Gửi duyệt </button>
                }
                else if (Model.Duyet != null && (Model.Duyet.nguoiDuyet.maNhanVien == null ? string.Empty : Model.Duyet.nguoiDuyet.maNhanVien.Trim()) == user1.manv && Model.Duyet.maBuocDuyet != "DTN" && Model.Duyet.maBuocDuyet != "CDL2" && Model.Duyet.maBuocDuyet != "CD")
                {
                <button class="btn btn-info" type="button" onclick="chonNguoiDuyet2();">Duyệt phiếu </button>
                <button class="btn btn-info" type="button" onclick="KhongDuyet();">Không duyệt</button>
                <button class="btn btn-info" type="button" onclick="TraLai();">Trả lại</button>
                }
                else if (Model.Duyet != null && (Model.Duyet.maBuocDuyet == "CDL2" || Model.Duyet.maBuocDuyet == "CD") && (Model.Duyet.nguoiDuyet.maNhanVien == null ? string.Empty : Model.Duyet.nguoiDuyet.maNhanVien.Trim()) == user1.manv && Model.Duyet.maBuocDuyet != "DTN")
                {
                <button class="btn btn-info" type="button" onclick="DuyetPhieu();">Duyệt</button>
                <button class="btn btn-info" type="button" onclick="KhongDuyet();">Không duyệt</button>
                <button class="btn btn-info" type="button" onclick="TraLai();">Trả lại</button>
                }
                else if (Model.Duyet != null && (nhanVienNS != null && nhanVienNS.Contains(user1.manv)) && Model.Duyet.maBuocDuyet == "CTN" && Model.Duyet.maBuocDuyet != "DTN")//Tất cả nhân viên ở phòng nhân sự đều được duyệt ở đấy
                {
                <button class="btn btn-info" type="button" onclick="DuyetPhieu();">Duyệt</button>
                <button class="btn btn-info" type="button" onclick="KhongDuyet();">Không duyệt</button>
                <button class="btn btn-info" type="button" onclick="TraLai();">Trả lại</button>
                }
            }
            <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
        </div>
    </fieldset>

</div>

