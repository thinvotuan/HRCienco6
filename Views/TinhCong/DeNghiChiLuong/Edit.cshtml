@using BatDongSan.Models.NhanSu;
@model DeNghiChiLuong
@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<link rel="stylesheet" href="~/Content/summernote/summernote.css" />
<script src="~/Content/summernote/summernote.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Content/bootstrap/js/bootstrap.min.js"></script>
<script src="~/Scripts/additional-methods.min.js"></script>
<script src="~/Scripts/autoNumeric.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>
<script src="~/Scripts/moment.min.js"></script>
<script src="~/Scripts/vi.js"></script>
<script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>
<link rel="stylesheet" href="~/Content/bootstrap-datetimepicker.min.css" />
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<script>
    $().ready(function () {
        $("#btnTroVe").click(function () {
            location.href = '@Url.Action("Index", "DeNghiChiLuong")';
        });
        $("#btnSubmit").click(function () {
            if (CheckForm()) {
                $("#form-submit").submit();
            }
        });
    });
    function CheckForm() {
        var flag = true;
        if ($("#noiDung").val() == "") {
            $("#noiDung").addClass("error").attr("title", "Vui lòng nhập nội dung.");
            flag = false;

        }
        return flag;
    }
    function chonNguoiDuyet(status, employeeId) {
        var url = ('@Url.Action("SelectCapDuyetDongERP/", "DMNguoiDuyet")' + $('#soPhieu').val() + '?maCongViec=DENGHICHILUONG' + '&url=' + $('#url').val());
        PopUpManager(url, "DUYET", 1000, 300);
    }
    function PopUpManager(url, title, w, h) {
        var left = (screen.width / 2) - (w / 2);
        var top = (screen.height / 2) - (h / 2);
        var targetWin = window.open(url, title, 'width=' + w + ', height=' + h + ', top=' + top + ', left=' + left);
    }
    function LoadLaiTrang() {
        location.href = '@Url.Action("Edit/", "DeNghiChiLuong")' + $('#soPhieu').val();
    }
</script>
@{
    BatDongSan.Models.HeThong.Sys_User user1 = new BatDongSan.Models.HeThong.Sys_User();
    if (Session["User"] != null)
    {
        user1 = (BatDongSan.Models.HeThong.Sys_User)Session["User"];
    }  
}
<form id="form-submit" class="form-horizontal" method="post">
    <div id="container" class="custome_fieldSet">
        <fieldset class="removeBorderFieldset">
            <div id="tabs" style="width: 30%; height: auto; border: none; float: left; box-sizing: border-box; overflow: hidden; clear: none;" class="ui-tabs ui-widget ui-widget-content ui-corner-all">
                <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                    <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active ">
                        <a><span><i class="fa fa-yelp" aria-hidden="true"></i>Cập nhật phiếu đề nghị chi lương</span></a></li>
                </ul>
            </div>
            <table class="table table-striped table-hover table-condensed" id="tbl-create" style="position: relative">
                <tr>
                    <td style="width: 15%" class="tdtitle">Số phiếu</td>
                    <td style="width: 35%">@Html.TextBoxFor(model => model.soPhieu, new { @class = "form-control", @readonly = true })</td>
                    <td style="width: 15%" class="tdtitle">Ngày lập</td>
                    <td style="width: 35%">
                        @Html.TextBoxFor(model => model.ngayLap, "{0: dd/MM/yyyy}", new { @class = "form-control datepicker", @readonly = true })
                        @Html.HiddenFor(m => m.maQuiTrinhDuyet)
                        <input type="hidden" name="maNVD" id="maNVD" value="@user1.manv" />
                        <input type="hidden" id="url" value="@ViewBag.URL" />
                    </td>
                </tr>
                <tr>
                    <td class="tdtitle">Tháng, Năm</td>
                    <td>
                        @Model.thang/@Model.nam
                        @Html.Hidden("thang", Model.thang)
                        @Html.Hidden("nam", Model.nam)
                    </td>
                    <td class="tdtitle">Người lập</td>
                    <td>
                        @Html.TextBoxFor(model => model.tenNguoiLap, new { @class = "form-control", @readonly = true })
                        @Html.Hidden("maNguoiLap", Model.maNguoiLap)
                    </td>
                </tr>
                <tr>
                    <td class="tdtitle">Nội dung</td>
                    <td colspan="3">
                        @Html.TextAreaFor(model => model.noiDung, new { @class = "form-control", @style = "font-size:13px" })
                    </td>
                </tr>
            </table>
            <table class="table table-striped table-hover table-condensed tableThemeCustome" id="tbl-child-create">
                <thead>
                    <tr>
                        <th>STT</th>
                        <th>Bộ phận tính lương</th>
                        <th>Lương tháng</th>
                        <th>Phụ cấp Công trình</th>
                        <th>Phụ cấp khác</th>
                        <th>BHXH</th>
                        <th>Thuế TNCN</th>
                        <th>Truy lãnh, truy thu</th>
                       
                        <th>Đoàn phí</th>
                        <th>Chuyển khoản</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        if (Model.DeNghiChiLuongChiTiet != null && Model.DeNghiChiLuongChiTiet.Count > 0)
                        {
                            var count = 0;
                            foreach (var item in Model.DeNghiChiLuongChiTiet)
                            {
                        <tr>
                            <td style="text-align: center">@(++count)</td>
                            <td>@item.TenBoPhanTinhLuong</td>
                            <td style="text-align: right">@string.Format("{0:#,##0}", item.LuongThang ?? 0)</td>
                            <td style="text-align: right">@string.Format("{0:#,##0}", item.PhuCapCT ?? 0)</td>
                            <td style="text-align: right">@string.Format("{0:#,##0}", item.PhuCapKhac ?? 0)</td>
                            <td style="text-align: right">@string.Format("{0:#,##0}", item.BHXH ?? 0)</td>
                            <td style="text-align: right">@string.Format("{0:#,##0}", item.ThueTNCN ?? 0)</td>
                            <td style="text-align: right">@string.Format("{0:#,##0}", item.TruyLanhTruyThu ?? 0)</td>
                            <td style="text-align: right">@string.Format("{0:#,##0}", item.DoanPhi ?? 0)</td>
                            <td style="text-align: right">@string.Format("{0:#,##0}", item.ChuyenKhoan ?? 0)
                                @Html.Hidden("TenBoPhanTinhLuong", item.TenBoPhanTinhLuong)
                                @Html.Hidden("LuongThang", item.LuongThang ?? 0)
                                @Html.Hidden("PhuCapCT", item.PhuCapCT ?? 0)
                                @Html.Hidden("PhuCapKhac", item.PhuCapKhac ?? 0)
                                @Html.Hidden("BHXH", item.BHXH ?? 0)
                                @Html.Hidden("ThueTNCN", item.ThueTNCN ?? 0)
                                @Html.Hidden("TruyLanhTruyThu", item.TruyLanhTruyThu ?? 0)
                                @Html.Hidden("ChuyenKhoan", item.ChuyenKhoan ?? 0)
                                @Html.Hidden("DoanPhi", item.DoanPhi ?? 0)
                            </td>
                            
                        </tr>
                            }
                        }
                    }
                </tbody>
                <tfoot>
                    <tr style="font-weight:bold">
                        <td colspan="2" style="text-align:center">Tổng</td>
                        <td style="text-align:right"><span id="lblLuongThang">@string.Format("{0:#,##0}", Model.DeNghiChiLuongChiTiet != null ? Model.DeNghiChiLuongChiTiet.Sum(d=>d.LuongThang) ?? 0: 0)</span></td>
                        <td style="text-align:right"><span id="lblPhuCapCT">@string.Format("{0:#,##0}", Model.DeNghiChiLuongChiTiet != null ? Model.DeNghiChiLuongChiTiet.Sum(d=>d.PhuCapCT) ?? 0: 0)</span></td>
                        <td style="text-align:right"><span id="lblPhuCapKhac">@string.Format("{0:#,##0}", Model.DeNghiChiLuongChiTiet != null ? Model.DeNghiChiLuongChiTiet.Sum(d=>d.PhuCapKhac) ?? 0: 0)</span></td>
                        <td style="text-align:right"><span id="lblBHXH">@string.Format("{0:#,##0}", Model.DeNghiChiLuongChiTiet != null ? Model.DeNghiChiLuongChiTiet.Sum(d=>d.BHXH) ?? 0: 0)</span></td>
                        <td style="text-align:right"><span id="lblThueTNCN">@string.Format("{0:#,##0}", Model.DeNghiChiLuongChiTiet != null ? Model.DeNghiChiLuongChiTiet.Sum(d=>d.ThueTNCN) ?? 0: 0)</span></td>
                        <td style="text-align:right"><span id="lblTruyLanhTruyThu">@string.Format("{0:#,##0}", Model.DeNghiChiLuongChiTiet != null ? Model.DeNghiChiLuongChiTiet.Sum(d=>d.TruyLanhTruyThu) ?? 0: 0)</span></td>
                         <td style="text-align:right"><span id="lblDoanPhi">@string.Format("{0:#,##0}", Model.DeNghiChiLuongChiTiet != null ? Model.DeNghiChiLuongChiTiet.Sum(d=>d.DoanPhi) ?? 0: 0)</span></td>
                        <td style="text-align:right"><span id="lblChuyenKhoan">@string.Format("{0:#,##0}", Model.DeNghiChiLuongChiTiet != null ? Model.DeNghiChiLuongChiTiet.Sum(d=>d.ChuyenKhoan) ?? 0: 0)</span></td>
                       
                        
                    </tr>
                </tfoot>
            </table>
            <div style="text-align: right; margin-bottom: 10px; margin-top: 10px">
                @if ((int)ViewBag.trangThai == 0 && Model.maNguoiLap == user1.manv)
                {
                    <button class="btn btn-info" type="button" onclick="chonNguoiDuyet();">Gửi duyệt </button>
                    <button class="btn btn-info" id="btnSubmit" type="button">Lưu </button>
                }

                <button class="btn btn-info" type="button" id="btnTroVe">Trở về </button>
            </div>
        </fieldset>
    </div>
</form>


