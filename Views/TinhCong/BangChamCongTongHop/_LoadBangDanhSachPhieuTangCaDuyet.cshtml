@using BatDongSan.Models.NhanSu
@{
    ViewBag.Title = "Index";
    Layout = null;
 
   
}
@{
                                
    int stt = 1;
    int page_ = Convert.ToInt32(ViewBag.page);
    int total_ = Convert.ToInt32(ViewBag.total);

    var ls = ViewData["lsDanhSach"] as List<sp_NS_PhieuDangKyTangCa_DuyetResult>;
    foreach (var item in ls.ToList())
    {
      
    <tr>
        <td align="center">
            @(stt++)
        </td>
        <td><a style="color:#519ee5; text-align:center;" href="@Url.Action("Details", "PhieuTangCa", new { id = item.soPhieuTangCa })">@item.soPhieuTangCa</a> </td>

        <td><a style="color:#519ee5" href="@Url.Action("Details", "NhanVien", new { id = item.maNhanVien })">@item.maNhanVien</a> / @item.maVanTay
            <br />
            <i class="fa fa-user" aria-hidden="true"></i> <span style="color:blue; font-weight:bold;">@item.tenNhanVien</span></td>

        <td style="text-align: center">
            <input type="hidden" name="soPhieu_Tab1" value="@item.soPhieuTangCa"/>
            <input type="hidden" name="maNhanVien_Tab1" value="@item.maNhanVien"/>
            <input type="hidden" name="ngayTangCa_Tab1" value="@string.Format("{0:dd/MM/yyyy}", item.ngayTangCa)"/>
            <input type="hidden" name="heSoTangCa_Tab1" value="@item.heSoTangCa"/>
            <input type="hidden" name="soGioTangCaHidden_Tab1" />
            <input type="hidden" name="timeNghiGiuaCaHidden_Tab1" />
            <input type="hidden" name="thoiGianNghiGiuaCa_Tab1" value="@string.Format("{0:HH\\:mm}", item.thoiGianNghiGiuaCa)"/>
            <input type="hidden" name="thoiGianNghiKetThucGiuaCa_Tab1" value="@string.Format("{0:HH\\:mm}", item.thoiGianNghiKetThucGiuaCa)"/>
            <span style="color:blue; font-weight:bold;">@string.Format("{0:dd/MM/yyyy}", item.ngayTangCa)</span> <br />
            @(item.tenNgay + "(" + item.heSoTangCa + ")"))
        </td>
        
        <td style="text-align: center">@string.Format("{0:HH\\:mm}", item.gioBatDau)</td>
        <td style="text-align: center">@string.Format("{0:HH\\:mm}", item.gioKetThuc)</td>
        <td style="text-align: center">
            BĐ: @string.Format("{0:HH\\:mm}", item.thoiGianNghiGiuaCa)<br />
            KT: @string.Format("{0:HH\\:mm}", item.thoiGianNghiKetThucGiuaCa)
        </td>

        <td style="text-align: center">@string.Format("{0:HH\\:mm}", item.gioQuetVanTayVao)</td>
        <td style="text-align: center">@string.Format("{0:HH\\:mm}", item.gioQuetVanTayRa)</td>
        <td style="text-align:center;">
            <input type="text"  name="duyetGioVao_Tab1" class="form-control" style="width: 70px; text-align:center" value="@string.Format("{0:HH\\:mm}", item.duyetGioVao)" readonly="readonly"/></td>
        <td>
            <input type="text"  name="duyetGioRa_Tab1" class="form-control" style="width: 70px; text-align:center" value="@string.Format("{0:HH\\:mm}", item.duyetGioRa)" readonly="readonly"/></td>
        <td style="text-align: center"><input type="text" name="soGioTangCa_Tab1" value="@item.soGioDuyet" style="width:50px; text-align:center;" class="form-control numberinputDec2" readonly="readonly"/></td>
        @*<td style="text-align:center">
            @if(item.ngayDuyetPhieu == null)
            {
                <input value="Duyệt" type="button" class="btn btn-info" name="btnDuyetPhieuTangCa" onclick="SaveDuyetTangCa(this);"/>
            }
            else
            {
                <input type="hidden" name="btnDuyetPhieuTangCa"/>
                @(string.Format("{0:dd/MM/yyyy}", item.ngayDuyetPhieu))
            }
        </td>*@
    </tr>
                           
    
    }
    <tr>
        <td colspan="13" style="text-align:right;">
        </td>
    </tr>
    
     
}

