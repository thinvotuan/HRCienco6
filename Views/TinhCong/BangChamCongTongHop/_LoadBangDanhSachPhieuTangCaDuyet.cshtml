<script>

    jQuery(document).ready(function ($) {
        $("#tbody_Tab1 tr").click(function () {
            $("#tbody_Tab1 tr").css({ "background": "none" });
            $(this).css({ "background": "yellow" });
        });

        //$("[name=duyetGioVao_Tab1]").timepicker({
        //    showAnim: 'blind'
        //});

        //$("[name=duyetGioRa_Tab1]").timepicker({
        //    showAnim: 'blind'
        //});

        $("[name=duyetGioVao_Tab1]").change(function () {
            var index = $("[name=duyetGioVao_Tab1]").index($(this));
            checkEndTime($("[name=duyetGioVao_Tab1]:eq(" + index + ")"), $("[name=duyetGioRa_Tab1]:eq(" + index + ")"), $("[name=thoiGianNghiGiuaCa_Tab1]:eq(" + index + ")"), $("[name=thoiGianNghiKetThucGiuaCa_Tab1]:eq(" + index + ")"), index);
        });

        $("[name=duyetGioRa_Tab1]").change(function () {
            var index = $("[name=duyetGioRa_Tab1]").index($(this));
            checkEndTime($("[name=duyetGioVao_Tab1]:eq(" + index + ")"), $("[name=duyetGioRa_Tab1]:eq(" + index + ")"), $("[name=thoiGianNghiGiuaCa_Tab1]:eq(" + index + ")"), $("[name=thoiGianNghiKetThucGiuaCa_Tab1]:eq(" + index + ")"), index);
        });


    });


    function checkEndTime(objGioBatDau, objGioKetThuc, objBatDauGiuaCa, objKetThucGiuaCa, index) {
        var valueStartTime = $(objGioBatDau).val();
        var valueEndTime = $(objGioKetThuc).val();
        var startTimeSplit = valueStartTime.split(':');
        var endTimeSplit = valueEndTime.split(':');
        if (parseFloat(endTimeSplit[0]) < parseFloat(startTimeSplit[0])) {
            $(objGioKetThuc).val('');
            $(objGioKetThuc).focus();
            $(objGioKetThuc).addClass("error").attr("title", "Giờ kết thúc > giờ bắt đầu");
        }
        else {
            if (parseFloat(endTimeSplit[0]) == parseFloat(startTimeSplit[0])) {
                if (parseFloat(endTimeSplit[1]) < parseFloat(startTimeSplit[1])) {
                    $(objGioKetThuc).val('');
                    $(objGioKetThuc).focus();
                    $(objGioKetThuc).addClass("error").attr("title", "Giờ kết thúc > giờ bắt đầu");
                }
            }
        }
        TinhThoiGianTangCa(objGioBatDau, objGioKetThuc, objBatDauGiuaCa, objKetThucGiuaCa, index);
    }
    function TinhThoiGianTangCa(objGioBatDau, objGioKetThuc, objBatDauGiuaCa, objKetThucGiuaCa, index) {
        var valueStartTime = $(objGioBatDau).val();
        var valueEndTime = $(objGioKetThuc).val();
        var startTimeSplit = valueStartTime.split(':');
        var endTimeSplit = valueEndTime.split(':');
        var starDateGio = parseFloat(startTimeSplit[0]);
        var startDatePhut = parseFloat(startTimeSplit[1]);
        var endDateGio = parseFloat(endTimeSplit[0]);
        var endDatePhut = parseFloat(endTimeSplit[1]);
        var soGio = 0;
        var soPhut = 0;
        var soPhutNew = 0;
        if (endDateGio >= starDateGio) {
            if (endDatePhut >= startDatePhut) {
                soGio = endDateGio - starDateGio;
                soPhut = endDatePhut - startDatePhut;
                if (soPhut < 10) { soPhut = "0" + soPhut }
                soPhutNew = soGio + ":" + soPhut;

                var soGioTangCa = (parseFloat(soGio) + (parseFloat(soPhut) / 60)).toFixed(2);



                $("[name=soGioTangCaHidden_Tab1]:eq(" + index + ")").val(soPhutNew);
                $("[name=soGioTangCa_Tab1]:eq(" + index + ")").val(soGioTangCa);
            }
            else {
                soGio = endDateGio - starDateGio - 1;
                soPhut = 60 - startDatePhut + endDatePhut;
                if (soPhut < 10) { soPhut = "0" + soPhut }

                soPhutNew = soGio + ":" + +soPhut;

                var soGioTangCa = (parseFloat(soGio) + (parseFloat(soPhut) / 60)).toFixed(2);

                $("[name=soGioTangCaHidden_Tab1]:eq(" + index + ")").val(soPhutNew);
                $("[name=soGioTangCa_Tab1]:eq(" + index + ")").val(soGioTangCa);
            }

        }
        GenerateSoGioTangCaNew(objBatDauGiuaCa, objKetThucGiuaCa, index);
    }

    function GenerateSoGioTangCaNew(objBatDauGiuaCa, objKetThucGiuaCa, index) {
        debugger;
        var valueStartTime = $(objBatDauGiuaCa).val();
        var valueEndTime = $(objKetThucGiuaCa).val();
        var startTimeSplit = valueStartTime.split(':');
        var endTimeSplit = valueEndTime.split(':');
        var starDateGio = parseFloat(startTimeSplit[0]);
        var startDatePhut = parseFloat(startTimeSplit[1]);
        var endDateGio = parseFloat(endTimeSplit[0]);
        var endDatePhut = parseFloat(endTimeSplit[1]);
        var soGio = 0;
        var soPhut = 0;
        var soPhutNew = 0;
        if (endDateGio >= starDateGio) {
            if (endDatePhut >= startDatePhut) {
                soGio = endDateGio - starDateGio;
                soPhut = endDatePhut - startDatePhut;

                soPhutNew = soGio * 60 + soPhut;

                var soPhut10 = soPhut;
                if (soPhut < 10) { soPhut10 = "0" + soPhut }
                var soPhutNew2 = soGio + ":" + soPhut10;
                $("[name=timeNghiGiuaCaHidden_Tab1]:eq(" + index + ")").val(soPhutNew2);
            }
            else {
                soGio = endDateGio - starDateGio - 1;
                soPhut = 60 - startDatePhut + endDatePhut;
                soPhutNew = soGio * 60 + soPhut;
                var soPhut10 = soPhut;
                if (soPhut < 10) { soPhut10 = "0" + soPhut }
                var soPhutNew2 = soGio + ":" + soPhut10;
                $("[name=timeNghiGiuaCaHidden_Tab1]:eq(" + index + ")").val(soPhutNew2);
            }

        }

        GenerateSoGioTangCaNew_SetValue(index);
    }
    function GenerateSoGioTangCaNew_SetValue(index) {
        var valueStartTime = $("[name=timeNghiGiuaCaHidden_Tab1]:eq(" + index + ")").val();
        var valueEndTime = $("[name=soGioTangCaHidden_Tab1]:eq(" + index + ")").val();
        var startTimeSplit = valueStartTime.split(':');
        var endTimeSplit = valueEndTime.split(':');
        var starDateGio = parseFloat(startTimeSplit[0]);
        var startDatePhut = parseFloat(startTimeSplit[1]);
        var endDateGio = parseFloat(endTimeSplit[0]);
        var endDatePhut = parseFloat(endTimeSplit[1]);
        var soGio = 0;
        var soPhut = 0;
        var soPhutNew = 0;
        if (endDateGio >= starDateGio) {
            if (endDatePhut >= startDatePhut) {
                soGio = endDateGio - starDateGio;
                soPhut = endDatePhut - startDatePhut;

                var soGioTangCa = (parseFloat(soGio) + (parseFloat(soPhut) / 60)).toFixed(2);

                $("[name=soGioTangCa_Tab1]:eq(" + index + ")").val(soGioTangCa);
            }
            else {
                soGio = endDateGio - starDateGio - 1;
                soPhut = 60 - startDatePhut + endDatePhut;

                var soGioTangCa = (parseFloat(soGio) + (parseFloat(soPhut) / 60)).toFixed(2);

                $("[name=soGioTangCa_Tab1]:eq(" + index + ")").val(soGioTangCa);
            }

        }
    }

</script>




