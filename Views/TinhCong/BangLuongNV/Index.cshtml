@using BatDongSan.Models.NhanSu
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
  
   
}

<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/additional-methods.min.js"></script>
<script src="~/Scripts/autoNumeric.js"></script>
<script src="~/Scripts/batdongsan.validate.js"></script>
<script src="~/Scripts/moment.min.js"></script>
<script src="~/Scripts/vi.js"></script>
<script src="~/Scripts/bootstrap-datetimepicker.min.js"></script>
<link rel="stylesheet" href="~/Content/bootstrap-datetimepicker.min.css" />
<script src="~/Scripts/batdongsan.utils.js"></script>
<link rel="stylesheet" href="~/Content/batdongsan-alert.css" />
<script type="text/javascript" src="~/Scripts/Jquery.treeview/jquery.treeview.js"></script>
<link rel="stylesheet" href="~/Scripts/Jquery.treeview/jquery.treeview.css" />
<script src="~/Scripts/jquery.unobtrusive-ajax.min.js"></script>
<style>
    .pageActive, .pageCurrent:hover, .pageNext:hover, .pageLast:hover, .pageFirst:hover, .pagePrevious:hover
    {
        padding: 7px 11px;
        background-color: #4D8AFF;
        color: #FFFFFF;
        display: inline-block;
        border: 1px solid #80ABFF;
        border-radius: 20px;
        text-decoration: none;
        font-weight: bold;
    }

    .pageCurrent, .pageNext, .pageLast, .pageFirst, .pagePrevious
    {
        padding: 7px 11px;
        background-color: #fff;
        display: inline-block;
        border: 1px solid #80ABFF;
        border-radius: 20px;
        font-weight: bold;
    }

    #navigation1
    {
        overflow: auto;
        height: 600px;
    }

    .infor_capnhat, .infor_LuongNV, .infor_DuyetLuongNV,.infor_SendBLLuongNV
    {
        padding: 5px;
        background: rgb(226, 144, 72);
        border-radius: 3px;
        color: #fff;
        box-sizing: border-box;
        margin: 5px auto;
        line-height: 1.7;
    }
</style>
<script type="text/javascript">
    $(document).ready(function () {

        //setting phong ban//
        $("#navigation1").treeview({
            persist: "location",
            unique: false,
            collapsed: true
        }).find(".expandable-hitarea").click();


        $('ul.dropdown-menu .hitarea').on('click', function (event) {
            event.stopPropagation();
        });

        $('#txtsearch').on("input", function () {

            $('#navigation1').filterLink($('#txtsearch').val());
        });

        $("#phongban-dropdown-menu").removeAttr("style");

        $("#customModal").on("hide.bs.modal", function () {
            $("#custom-panel").html("");
        });


        $(document).on("click", "#phongban-dropdown-menu li a", function () {

            $("#btnPhongBan").val(this.id);
            $(this).parents(".dropdown").find('.btn').html($(this).text() + ' &nbsp;<span class="caret"></span>');
            $("#btnSearch").click();
        })
        //End
        $(".tabToggle").click(function () {
            $(".tabToggle").removeClass("ui-tabs-selected ui-state-active activeColorTab");
            $(".contentToggle").hide(300);
            var index = $(".tabToggle").index(this);
            $(".tabToggle").eq(index).addClass("ui-tabs-selected ui-state-active activeColorTab");
            $(".contentToggle").eq(index).show(300);
        });
        $(".datepicker").datetimepicker({
            locale: 'vi',
            format: 'DD/MM/YYYY'
        });
        $("#btnSearch").click(function () {

            $(".infor_LuongNV,.infor_DuyetLuongNV,.infor_SendBLLuongNV").css('display', 'none');
            Search();
        });
        $("#btnSearchBP").click(function () {
            SearchBP();
        });
        $("#thang,#nam").change(function () {
            $(".infor_LuongNV,.infor_DuyetLuongNV,.infor_SendBLLuongNV").css('display', 'none');
            Search();
        });
        $("#thangBP,#namBP").change(function () {
            SearchBP();
        });

        $("#btnTaoDeNghiChiLuong").click(function () {
            $.post('@Url.Action("CheckTaoDNCL","BangLuongNV")', { thang: $("#thangBP").val(), nam: $("#namBP").val() }, function (data) {
                if (data == "") {
                    var urlLink = '@Url.Action("CreateCL", "BangLuongNV")' + "?thang=" + $("#thangBP").val() + "&nam=" + $("#namBP").val();
                    window.open(urlLink, "_blank");
                }
                else {
                    Alert.error("Bạn đã tạo đề nghị chi lương tháng: " + $("#thangBP").val() + "/" + $("#namBP").val() + ".", "Thông báo", { displayDuration: 3000 });
                }
            });
        });


        Search();
        // Cap nhat bang luong chi tiet
        $(document).on('click', '#btnTinhluongNV', function () {
            var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
            $('.infor_LuongNV').html(imageUrl).css('display', 'block');
            $.ajax({

                type: "POST",
                url: '@Url.Action("UpdateLuongNV", "BangLuongNV")',
                data: {
                    'nam': $("#nam").val(),
                    'thang': $("#thang").val()

                },
                success: function (result) {
                    $(".infor_LuongNV").css('display', 'block');

                    if (result.kq == true) {
                        $(".infor_LuongNV").html('Cập nhật thành công bảng lương nhân viên tháng: ' + $("#thang").val() + " năm: " + $("#nam").val());
                    }
                    else {
                        $(".infor_LuongNV").html('Cập nhật thất bại bảng lương nhân viên tháng: ' + $("#thang").val() + " năm: " + $("#nam").val());
                    }

                    Search();
                }
            });

        });
        $(document).on('click', '#btnXuatFileBLNV', function () {
            var url = '@Url.Action("XuatFileBLNV", "BangLuongNV")' + "?thang=" + $("#thang").val() + "&nam=" + $("#nam").val();

            window.location = url;

        });
        $(document).on('click', '#btnXuatFileBLNV_TrinhKy', function () {
            var url = '@Url.Action("XuatFileBLNV_TrinhKy", "BangLuongNV")' + "?thang=" + $("#thang").val() + "&nam=" + $("#nam").val();

             window.location = url;

        });

        $(document).on('click', '#btnXuatFileBLNVBoPhan', function () {

            var url = '@Url.Action("XuatFileBLNVBoPhan", "BangLuongNV")' + "?thang=" + $("#thangBP").val() + "&nam=" + $("#namBP").val();

            window.location = url;

        });
        $(document).on('click', '#btnDuyetBLNV', function () {
            bootbox.confirm("Bạn có chắc chắn duyệt bảng lương? Sau khi duyệt bảng lương sẽ được đóng.", function (result) {
                if (result) {
                    var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
                    $('.infor_DuyetLuongNV').html(imageUrl).css('display', 'block');
                    $.ajax({

                        type: "POST",
                        url: '@Url.Action("DuyetLuongNV", "BangLuongNV")',
                        data: {
                            'nam': $("#nam").val(),
                            'thang': $("#thang").val()

                        },
                        success: function (result) {
                            $(".infor_DuyetLuongNV").css('display', 'block');

                            if (result.kq == true) {
                                $(".infor_DuyetLuongNV").html('Đã duyệt bảng lương nhân viên tháng: ' + $("#thang").val() + " năm: " + $("#nam").val());
                            }
                            else {
                                $(".infor_DuyetLuongNV").html('Duyệt bảng lương nhân viên thất bại tháng: ' + $("#thang").val() + " năm: " + $("#nam").val());
                            }

                            Search();
                        }
                    });
                }
            });
        });
        $(document).on('click', '#btnSendMailNV', function () {


            var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
            $('.infor_SendBLLuongNV').html(imageUrl).css('display', 'block');
            $.ajax({

                type: "POST",
                url: '@Url.Action("SendBangLuongNV", "BangLuongNV")',
                data: {
                    'nam': $("#nam").val(),
                    'thang': $("#thang").val()

                },
                success: function (result) {
                    $(".infor_SendBLLuongNV").css('display', 'block');

                    if (result.kq == true) {
                        $(".infor_SendBLLuongNV").html('Đã gửi mail nhân viên tháng: ' + $("#thang").val() + " năm: " + $("#nam").val());
                    }
                    else {
                        $(".infor_SendBLLuongNV").html('Gửi mail nhân viên thất bại tháng: ' + $("#thang").val() + " năm: " + $("#nam").val());
                    }

                    Search();
                }
            });
        });
                
           

    });
    function OnCriteriaPC(page) {
        var giatri = $("#qSearch").val().trim();
        giatri = giatri.replace(/ /gi, '+');
        var url = '@Url.Action("LoadBangLuongNV", "BangLuongNV")' + "?thang=" + $("#thang").val() + "&nam=" + $("#nam").val() + "&qSearch=" + giatri + "&_page=" + page;
        var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
        $('#tbody').html(imageUrl);
        $('#tbody').load(url, function () {
        });
    }

    function Search() {

        var giatri = $("#qSearch").val().replace(/ /gi, '+');
        giatri = giatri.replace(/ /gi, '+');


        var url = '@Url.Action("LoadBangLuongNV", "BangLuongNV")' + "?thang=" + $("#thang").val() + "&nam=" + $("#nam").val() + "&maPhongBan=" + $("#btnPhongBan").val() + "&qSearch=" + giatri + "&_page=0";

        var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
        $('#tbody').html(imageUrl);
        $('#tbody').load(url, function () {
            var checkDuyet = $("#checkDuyet").val();
           
            if (checkDuyet == 1) {
                $("#btnTinhluongNV,#btnDuyetBLNV").css("display", "none");
                $("#btnSendMailNV").css("display","block");
            }
            else {
                $("#btnTinhluongNV,#btnDuyetBLNV").css("display", "block");
                $("#btnSendMailNV").css("display","none");
            }

        });
    }



    function enterToSeacrh(event) {
        if (event.keyCode == 13)
            $("#btnSearch").click();
    }
    function OnCriteriaPCTC(page) {

        var url = '@Url.Action("LoadPhanCaNhanVienChiTiet", "PhanCaNhanVien")' + "?thang=" + $("#thangBP").val() + "&nam=" + $("#namBP").val() + "&_page=" + page;
        var imageUrl = '<div id="divMsgTC" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
        $('#contentBP').html(imageUrl);
        $('#contentBP').load(url, function () {
        });
    }

    function enterToSeacrhBP(event) {
        if (event.keyCode == 13)
            $("#btnSearchBP").click();
    }
    function SearchBP() {



        var url = '@Url.Action("LoadBangLuongTheoBP", "BangLuongNV")' + "?thang=" + $("#thangBP").val() + "&nam=" + $("#namBP").val() + "&_page=0";

        var imageUrl = '<div id="divMsgTC" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
        $('#contentBP').html(imageUrl);
        $('#contentBP').load(url, function () {
        });
    }

    function beginPaging() {
    }
    function successPaging() {
    }

</script>



<fieldset class="removeBorderFieldset">

    <div id="tabs" style="" class="ui-tabs">
        <ul class="ui-tabs-nav">
            <ul class="ui-tabs-nav ui-helper-reset ui-helper-clearfix ui-widget-header ui-corner-all">
                <li class="ui-state-default ui-corner-top ui-tabs-selected ui-state-active activeColorTab tabToggle">
                    <a href="#"><span><i class="fa fa-object-group" aria-hidden="true"></i>Bảng lương nhân viên</span></a>

                </li>
                <li class="ui-state-default ui-corner-top tabToggle">
                    <a href="#"><span><i class="fa fa-users" aria-hidden="true"></i>Bảng lương theo bộ phận</span></a></li>


            </ul>

        </ul>
    </div>
    <div id="container">
        <div class="contentToggle" style="display: block;">
            <div id="filter-panel" class="collapse filter-panel" style="display: block; position: relative">
                <div class="panel panel-default background_top">
                    <div class="panel-body">
                        <div style="line-height: 26px; float: left">
                            <div style="float: left">
                                Tháng:@Html.DropDownList("thang", ViewData["lstThang"] as SelectList, new { @style = "" })
                                Năm:@Html.DropDownList("nam", ViewData["lstNam"] as SelectList, new { @style = "" })
                            </div>

                            <div class="form-group" id="phongban-div" style="float: left; margin-left: 10px;">
                                <div class="dropdown">
                                    <button class="btn btn-primary btn-sm dropdown-toggle" id="btnPhongBan" type="button" data-toggle="dropdown">
                                        Danh sách phòng ban&nbsp;<span class="caret"></span>
                                    </button>
                                    <ul class="dropdown-menu" id="phongban-dropdown-menu">
                                        <li role="presentation">
                                            <div class="form-group has-feedback" style="width: 90%; margin: 5px auto !important; display: block;">
                                                <input type="text" class="form-control input-sm" id="txtsearch" placeholder="Search" style="width: 100%" />
                                                <span class="glyphicon glyphicon-search form-control-feedback"></span>
                                            </div>
                                        </li>
                                        <li role="presentation">
                                            @Html.Raw(ViewBag.PhongBans)
                                        </li>
                                    </ul>
                                </div>
                            </div>


                        </div>
                        <div style="float: right">
                            <input type="text" id="qSearch" value="@ViewBag.Search" class="form-control" style="width:200px;float:left;margin-right:5px" placeholder="Nhập giá trị tìm kiếm" onkeypress="enterToSeacrh(event);" />
                            <button class="btn btn-info" id="btnSearch" type="button" style="margin-top: 2px; float: left; margin-left: 2px">Tìm kiếm</button>
                            <button class="btn btn-info" id="btnTinhluongNV" type="button" style="margin-top: 2px; float: left; margin-left: 10px !important">Tính lương nhân viên</button>
                            <button class="btn btn-info" id="btnDuyetBLNV" type="button" style="margin-top: 2px; float: left; margin-left: 10px !important">Duyệt</button>
                            <button class="btn btn-info" id="btnXuatFileBLNV" type="button" style="margin-top: 2px; float: left; margin-left: 10px !important">Xuất File chi tiết</button>
                            <button class="btn btn-info" id="btnXuatFileBLNV_TrinhKy" type="button" style="margin-top: 2px; float: left; margin-left: 10px !important">Xuất File trình ký</button>

                            <button class="btn btn-info" id="btnSendMailNV" type="button" style="margin-top: 2px; float: left; margin-left: 10px !important">Send mail NV</button>

                        </div>

                    </div>
                </div>
            </div>
            <div class="infor_LuongNV" style="display: none"></div>
            <div class="infor_DuyetLuongNV" style="display: none"></div>
            <div class="infor_SendBLLuongNV" style="display: none"></div>

            <table style="width: 100%" class="table table-striped table-hover table-condensed tableThemeCustome">

                <thead>
                    <tr>
                        <th style="width: 35px; text-align: center">STT
                        </th>
                        <th style="text-align: center">Nhân viên
                        </th>

                        <th style="text-align: center">Phòng ban
                            <br />
                            chức vụ
                        </th>

                        <th style="text-align: center">Tổng lương</th>
                        <th style="text-align: center">Tổng ngày<br />
                            công</th>

                        <th style="text-align: center">Bảo hiểm</th>
                        <th style="text-align: center">Thuế</th>
                        <th style="text-align: center">Truy thu</th>
                        <th style="text-align: center">Truy lãnh</th>
                        <th style="text-align: center">Thực lãnh</th>
                        <th style="text-align: center">Chi tiết</th>



                    </tr>
                </thead>
                <tbody id="tbody">
                </tbody>


            </table>
        </div>
        <div class="contentToggle" style="display: none">
            <div id="filter-panel" class="collapse filter-panel" style="display: block; position: relative">
                <div class="panel panel-default background_top">
                    <div class="panel-body">
                        <div style="line-height: 26px; float: left">
                            <div style="float: left">
                                Tháng:@Html.DropDownList("thangBP", ViewData["lstThang"] as SelectList, new { @style = "" })
                                Năm:@Html.DropDownList("namBP", ViewData["lstNam"] as SelectList, new { @style = "" })
                            </div>





                        </div>
                        <div style="float: right">
                            <button class="btn btn-info" id="btnTaoDeNghiChiLuong" type="button" style="margin-top: 2px; float: left; margin-left: 2px">Tạo đề nghị chi lương</button>
                            <button class="btn btn-info" id="btnSearchBP" type="button" style="margin-top: 2px; float: left; margin-left: 2px">Tìm kiếm</button>
                            <button class="btn btn-info" id="btnXuatFileBLNVBoPhan" type="button" style="margin-top: 2px; float: left; margin-left: 10px !important">Xuất File</button>

                        </div>

                    </div>
                </div>
            </div>
            <table style="width: 100%" class="table table-striped table-hover table-condensed tableThemeCustome">

                <thead>
                    <tr>
                        <th style="width: 35px; text-align: center">STT
                        </th>
                        <th style="text-align: center">Phòng ban</th>

                        <th style="text-align: center">Tháng</th>

                        <th style="text-align: center">Năm
                        </th>

                        <th style="text-align: center">Tổng lương</th>

                        <th style="text-align: center">Bảo hiểm</th>
                        <th style="text-align: center">Thuế</th>
                        <th style="text-align: center">Truy thu</th>
                        <th style="text-align: center">Truy lãnh</th>
                        <th style="text-align: center">Đoàn phí</th>
                        <th style="text-align: center">Thực lãnh</th>



                    </tr>
                </thead>
                <tbody id="contentBP">
                </tbody>


            </table>


        </div>
        <div id="myModalChonPhongBan" class="modal fade" role="dialog">
            <div class="modal-dialog modal-lg">
                <!-- Modal content-->
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                        <h4 class="modal-title"></h4>
                    </div>
                    <div class="modal-body">

                        <div class="container" style="width: 98%">
                            <div class="row">
                                <div id="filter-panel1" class="filter-panel">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                    </div>
                </div>

            </div>
        </div>
    </div>
</fieldset>
