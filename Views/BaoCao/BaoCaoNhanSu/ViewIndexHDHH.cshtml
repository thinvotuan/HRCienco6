@using BatDongSan.Models.NhanSu;
@{
    int i = 1;
    int page_ = Convert.ToInt32(ViewBag.page);
    int total_ = Convert.ToInt32(ViewBag.total);
}
<script>
    function beginPaging(args) {
        // Animate        
        $('#content').fadeOut('fast');
    }

    function successPaging() {
        // Animate
        $('#content').fadeIn('normal');
    }

    function failurePaging() {
        alert("Không thể tải dữ liệu");
    }

</script>
<table class="table table-striped table-hover table-condensed" id="maintable">
    <thead>
        <tr>
            <th style="width: 45px">STT</th>
            <th style="width: 130px">Nhân viên</th>
            <th style="width: 200px">Phòng ban/Chức vụ</th>
            <th style="width: 80px">Hợp đồng</th>
            <th style="width: 80px">Ngày ký</th>
            <th style="width: 80px">Ngày hết hạn</th>
            <th style="width: 80px">Thâm niên</th>
            <th style="width: 80px">Số ngày đến hạn</th>

        </tr>
    </thead>
    <tbody id="load">

             @{
            var ls = ViewData["lsDanhSach"] as List<sp_BC_NS_HopDongSapHetHanResult>;
            if (ls != null)
            {
                foreach (var item in ls.ToList())
                {  
            <tr>
                <td style="text-align: center">@i</td>

                <td style="text-align: left"><a style="color:#519ee5" target="_blank" href="/NhanVien/Details/@item.maNhanVien">@item.maNhanVien</a><br />
                    <i class="fa fa-user" aria-hidden="true"></i>@item.hoTen</td>
                <td>@item.tenPhongBan<br />
                    <i class="fa fa-ticket" aria-hidden="true"></i>@item.TenChucDanh</td>
                <td style="text-align: center"><a style="color:#519ee5" href="@Url.Action("Details", "HopDongLaoDong", new { id=item.soHopDong})" target="_blank">@item.soHopDong</a></td>                
                <td style="text-align: center">@String.Format("{0:dd/MM/yyyy}", item.ngayKy)</td>                
                <td style="text-align: center">@String.Format("{0:dd/MM/yyyy}", item.ngayHetHan)</td> 
                <td style="text-align: right">@String.Format("{0:#,#0.#}", item.thamNien)</td>
                <td style="text-align: right">@String.Format("{0:#,#0.#}", item.soNgayDenHan)</td>               
            </tr> 
            i++;
        }
        }
        }
        <tr>
            <td colspan="8" style="text-align: left">
                @{
                
                    if (page_ > 1)
                    {
        
                    <a class="pageFirst" href="javascript:void(0)" onclick="javascript:OnCriteriaPC(1);">First</a> <a class="pagePrevious" href="javascript:void(0)" onclick="javascript:OnCriteriaPC(@(page_ - 1));">
                Previous</a>
       
                    }


                    if (page_ - 2 >= 1)
                    { 
                    <a class="pageCurrent" href="javascript:void(0)" onclick="javascript:OnCriteriaPC(@(page_ - 2));">
                        @(page_ - 2) </a> <a class="pageCurrent" href="javascript:void(0)" onclick="javascript:OnCriteriaPC(@(page_ - 1));">
                            @(page_ - 1) </a>
                    } <span class="pageActive">@page_</span>
                    if (page_ + 2 <= total_)
                    { 
                    <a class="pageCurrent" href="javascript:void(0)" onclick="javascript:OnCriteriaPC(@(page_ + 1) );">
                        @(page_ + 1) </a> <a class="pageCurrent" href="javascript:void(0)" onclick="javascript:OnCriteriaPC(@(page_ + 2));">
                            @(page_ + 2) </a>
                    }

                    if (page_ < total_)
                    { 
        
                    <a class="pageNext" href="javascript:void(0)" onclick="javascript:OnCriteriaPC(@(page_ + 1));">Next</a> <a class="pageLast" href="javascript:void(0)" onclick="javascript:OnCriteriaPC(@total_);">
                Last</a>
        
                    }
        
                    <span>Tổng số dòng :</span><strong>@ViewBag.totalRow</strong>
                }
            </td>
        </tr>
    </tbody>
</table>