        //    $("#alertPhanBo").show();
        //    setTimeout(function () { $("#alertPhanBo").fadeOut("normal"); }, 4000);
        //    return false;
        //}

        //if (isNaN(tongLoaiII) || (tongLoaiII != phuCapTheoTiLe)) {
