</script>
<style>
    td
    {
        border: none!important;
    }

    .input-group-btn
    {
        position: absolute;
        font-size: 0;
    }

    .numberinput
    {
        text-align: right;
    }
</style>
<form id="form-submit" method="post" action="/LuongChoViec/Edit" enctype="multipart/form-data">
    <fieldset class="removeBorderFieldset">
        <div id="tabs">
            <ul class="ui-tabs-nav">
                <li class="ui-tabs-selected active">
                    <a href="#tab1" data-toggle="tab"><span>Cập nhật lương chờ việc</span></a></li>
            </ul>
        </div>
        <div class="tab-content">
            <div class="tab-pane in active" id="tab1">
                <table class="table table-hover table-striped table-condensed" style="position: relative">
                    <tr>
                        <td class="tdtitle" style="width: 15%">Nhân viên <span style="font-style: italic; float: right; color: red">*</span></td>
                        <td style="width: 35%">
                            <div style="display: inline-flex; width: 100%;">
                                <input type="text" name="tenNhanVien" id="tenNhanVien" readonly="true" value="@Model.NhanVien.hoVaTen" class="form-control" required="required" />
                                @Html.HiddenFor(model => model.NhanVien.maNhanVien, new { required = "required" })
                            </div>
                        </td>
                        <td class="tdtitle" style="width: 15%">Chức danh</td>
                        <td style="width: 35%">
                            <input name="tenChucDanh" id="tenChucDanh" class="form-control" readonly="readonly" /></td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Mã hợp đồng <span style="font-style: italic; float: right; color: red">*</span></td>
                        <td>@Html.TextBoxFor(model => model.soHopDong, new { @class = "form-control", @readonly = "readonly" })
                            <span style="color: red; font-style: italic">@TempData["SoHopDong"]</span>
                        </td>
                        <td class="tdtitle">Tên hợp đồng<span style="font-style: italic; float: right; color: red">*</span></td>
                        <td>
                            @Html.TextBoxFor(model => model.tenHopDong, new { @class = "form-control", @readonly = "readonly" })
                            @Html.HiddenFor(model => model.soPhuLuc, new { @class = "form-control", @readonly = "readonly" })
                        </td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Mã chờ việc <span style="font-style: italic; float: right; color: red">*</span></td>
                        <td>@Html.TextBoxFor(model => model.maLuongChoViec, new { @class = "form-control", required = "required", @readonly = "readonly" })
                            <span style="color: red; font-style: italic">@TempData["SoHopDong"]</span>
                        </td>

                        <td class="tdtitle">Ngày lập<span style="font-style: italic; float: right; color: red">*</span></td>
                        <td>
                            @Html.TextBoxFor(model => model.ngayLap, "{0:dd/MM/yyyy}", new { @class = "form-control datepicker", required = "required" })

                        </td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Áp dụng từ</td>
                        <td colspan="3">Tháng:@Html.DropDownList("thang", ViewData["lstThang"] as SelectList, new { @style = "width:150px" })
                            Năm:@Html.DropDownList("nam", ViewData["lstNam"] as SelectList, new { @style = "width:150px" })</td>

                    </tr>
                    <tr>
                        <td class="tdtitle">Lương (1)</td>
                        <td>
                            @Html.TextBoxFor(model => model.luongThoaThuan, new { @class = "form-control numberinput", @readonly = "readonly" })
                        </td>
                        <td class="tdtitle">Phụ cấp lương (2)</td>
                        <td>
                            @Html.TextBoxFor(model => model.phuCapLuong, new { @class = "form-control numberinput", @readonly = "readonly" })
                        </td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Lương đóng BH (3=1+2)</td>
                        <td>
                            @Html.TextBoxFor(model => model.luongDongBH, new { @class = "form-control numberinput", @readonly = "readonly" })
                        </td>

                        <td class="tdtitle">Khoản bổ sung lương (4)</td>
                        <td>
                            @Html.TextBoxFor(model => model.khoanBoSungLuong, new { @class = "form-control numberinput", required = "required", @readonly = "readonly" })
                        </td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Tổng lương (5=3+4)</td>
                        <td>@Html.TextBoxFor(model => model.tongLuong, new { @class = "form-control numberinput", @readonly = "readonly" })</td>
                        <td class="form-inline tdtitle">Công chờ việc</td>
                        <td>@Html.TextBoxFor(model => model.congChoViec, new { @class = "form-control numberinput", required = "required" })</td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Tỷ lệ</td>
                        <td>@Html.TextBoxFor(model => model.tyLeLuongChoViec, new { @class = "form-control numberinput", style = "width: 100%", data_v_max = "500", data_a_sign = " %" })</td>

                        <td class="form-inline tdtitle">Lương chờ việc</td>
                        <td>@Html.TextBoxFor(model => model.luongChoViec, new { @class = "form-control numberinput" })</td>
                    </tr>
                    <tr>
                        <td class="tdtitle">Ghi chú</td>
                        <td colspan="3">
                            <textarea class="form-control" name="ghiChuMain" id="ghiChuMain">@Model.ghiChu</textarea>

                        </td>
                    </tr>
                </table>
            </div>
        </div>
        <div class="form-group" style="float: right">
            <button class="btn btn-info" id="btnSubmit">Lưu </button>
            <button class="btn btn-info btnTroVe" type="button" id="btnTroVe">Trở về </button>
        </div>
    </fieldset>
</form>
<div id="customModal" class="modal fade" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                <h4 class="modal-title"></h4>
            </div>
            <div class="modal-body">
                <div class="container" style="width: 100%">
                    <div class="row">
                        <div id="custom-panel" class="filter-panel">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
