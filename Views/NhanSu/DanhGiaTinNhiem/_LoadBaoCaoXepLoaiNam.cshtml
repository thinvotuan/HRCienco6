<form method="post" id="frmCreate">

    <div class="box_TiLeKhenThuongTheoXepHang">

        <input type="hidden" value="" name="namThuHang" id="namThuHang" />
        <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-bottom: 1px;">
            <h4 class="col-md-8 tieudeGroup" style="color: #1b809e; margin: 0px;"><b></b>Tỉ lệ khen thưởng theo xếp hạng<span style="color: red; font-style: italic"></span></h4>
            <button class="col-md-4 btn btn-info" id="btnResetTiLeKT" style="float: right" type="button">Khởi tạo giá trị ban đầu </button>
        </div>
        <div class="content_tiLeKhenThuongTheoXephang">
            <div class="infor_tiLeKhenThuongTheoXephang" style="display: none"></div>

            <table class="table table-striped table-hover table-condensed">
                <thead>
                    <tr>
                        <th rowspan="2" style="width: 90px;">Thứ hạng</th>
                        <th rowspan="2" style="width: 70px;" title="Số lượng nhân viên">SLNV</th>
                        @{
                            if (listTheoHangIndex != null && countHang != 0)
                            {
                                for (var i = 0; i < totalHang / countHang; i++)
                                {
                                    var clsLoai = listTheoHangIndex[i].maLoai;
                                    if (listTheoHangIndex[i].maLoai == "A+")
                                    {
                                        clsLoai = "AA";
                                    }
                                    if (listTheoHangIndex[i].maLoai == "B+")
                                    {
                                        clsLoai = "BB";
                                    }


                            <th colspan="2" class="@clsLoai">@listTheoHangIndex[i].tenXepLoai</th>
                                }
                            }

                        }


                    </tr>
                    <tr>
                        @{ 
                            if (listTheoHangIndex != null && countHang != 0)
                            {

                                for (var i = 0; i < totalHang / countHang; i++)
                                {
                                    var clsLoai = listTheoHangIndex[i].maLoai;
                                    if (listTheoHangIndex[i].maLoai == "A+")
                                    {
                                        clsLoai = "AA";
                                    }
                                    if (listTheoHangIndex[i].maLoai == "B+")
                                    {
                                        clsLoai = "BB";
                                    }
                            <th  class="@clsLoai">%</th>
                            <th  class="@clsLoai">SL</th>
                                }
                            }
                        }



                    </tr>
                </thead>
                <tbody>
                    @{
                        if (listTheoHangIndex != null)
                        {
                            var stt = 0;
                            for (var thuHang = 0; thuHang < countHang; thuHang++)
                            {      
                        <tr class="inforThuHang" style="display: none">
                            <td colspan="14">
                                <div class="inforSLHang">
                                    Tổng số lượng phải bằng: (@listHangDist[thuHang].soLuongNV).
                                         
                                </div>
                                <div class="inforTLHang"></div>
                            </td>
                        </tr>
                        <tr class="parentThuHang" id="parentThuHang_@thuHang">
                            <td style="text-align: center">Hạng: @listHangDist[thuHang].thuTuHang


                            </td>
                            <td class="numberinputInt" style="text-align: right">@listHangDist[thuHang].soLuongNV

                            </td>
                            @{
                                var whereHang = listTheoHangIndex.Where(t => t.thuTuHang == listHangDist[thuHang].thuTuHang).ToList();

                                foreach (var itemChiTietHang in whereHang)
                                {
                                    var chiTietHang = "chiTietHang_" + stt;
                                <td class="@chiTietHang">
                                    <input type="hidden" name="thuTuHang" value="@listHangDist[thuHang].thuTuHang" />
                                    <input type="hidden" name="soLuongNV" value="@listHangDist[thuHang].soLuongNV" />
                                    <input type="hidden" name="maLoaiHang" value="@itemChiTietHang.maLoai" />
                                    <input type="hidden" name="tiLeChoi" value="@itemChiTietHang.tiLeChoi" class="numberinput" style="text-align:right" />
                                    <input type="text" name="tilephantram" value="@itemChiTietHang.phanTram" class="numberinput" style="text-align:right" /></td>
                                <td class="@chiTietHang">
                                    <input type="text" name="soLuongHang" value="@itemChiTietHang.soLuong" class="numberinputInt" style="text-align:right" /></td>
                                    stt++;
                                }
                            }

                        </tr>
                            
                            }
                        }
                    }
                    <tr>
                        <td colspan="14" style="text-align: right">
                            <input type="button" class="btnAdd btnTiLeKTXH" value="Lưu" onclick="goSubmit()" /></td>
                    </tr>

                </tbody>

            </table>
        </div>
    </div>

</form>
<!--Xếp loại theo bộ phận-->
<form id="frmCreateXLBP" method="post">
    <input type="hidden" value="" name="namThuHangXLBP" id="namThuHangXLBP" />
    <div class="box_XepLoaiTheoBoPhan">
        <div class="form-group bs-callout bs-callout-info" style="overflow: hidden; margin-bottom: 1px;">
            <h4 class="col-md-12 tieudeGroup" style="color: #1b809e; margin: 0px;"><b></b>Xếp loại theo bộ phận<span style="color: red; font-style: italic"></span></h4>
        </div>
        <div class="content_XepLoaiTheoBoPhan">

            <table class="table table-striped table-hover table-condensed">
                <thead>
                    <tr>
                        <th style="width: 90px;">Thứ hạng</th>
                        <th style="">Bộ phận</th>
                        <th style="width: 70px;">SLNV</th>
                        @{
                            if (listTheoHangIndex != null && countHang != 0)
                            {
                                for (var i = 0; i < totalHang / countHang; i++)
                                {
                                    var clsLoai = listTheoHangIndex[i].maLoai;
                                    if (listTheoHangIndex[i].maLoai == "A+")
                                    {
                                        clsLoai = "AA";
                                    }
                                    if (listTheoHangIndex[i].maLoai == "B+")
                                    {
                                        clsLoai = "BB";
                                    }


                            <th  class="@clsLoai">@listTheoHangIndex[i].tenXepLoai</th>
                                }
                            }

                        }
                    </tr>
                </thead>
                <tbody>

                    @{
                        if (listXLTheoBoPhan != null)
                        {
                            foreach (var itemXepLoaiBoPhan in hangDistinceBoPhan)
                            {
                                var rowSpanPB = listXLTheoBoPhan.Where(d => d.thuHang == itemXepLoaiBoPhan.thuHang).Select(d => d.tenPhongBan).ToList();
                                var colRow = rowSpanPB.Count();
@*<tr>
                        <td rowspan="@colRow">@itemXepLoaiBoPhan.thuHang</td>
                        @{
                            foreach(var itemPhongBan in rowSpanPB){
                            <td>@itemPhongBan</td>
                            }
                            
                            }
                    </tr>*@
                            }
                        }
                    }
                    @{
                        double totalSoLuongNVPB = 0;
                        double totalXuatSac = 0;
                        double totalLoaiAA = 0;
                        double totalLoaiA = 0;
                        double totalLoaiBB = 0;
                        double totalLoaiB = 0;
                        double totalLoaiC = 0;
                        if (listXLTheoBoPhan != null && listXLTheoBoPhan.Count() > 0)
                        {

                            var thuHangBanDau = listXLTheoBoPhan[0].thuHang;
                            var flashHang = 0;
                            var rowSpanPB = listXLTheoBoPhan.Where(d => d.thuHang == thuHangBanDau).Count();
                            for (var thuTuXL = 0; thuTuXL < listXLTheoBoPhan.Count(); thuTuXL++)
                            {
                                flashHang = 0;
                                if (listXLTheoBoPhan[thuTuXL].thuHang != thuHangBanDau && thuTuXL != 0)
                                {
                                    thuHangBanDau = listXLTheoBoPhan[thuTuXL].thuHang;
                                    rowSpanPB = listXLTheoBoPhan.Where(d => d.thuHang == thuHangBanDau).Count();
                                    flashHang = 1;
                                }
                                if (thuTuXL == 0) { flashHang = 1; }
                           
                        <tr>
                            @{
                                if (flashHang == 1)
                                {
                                <td rowspan="@rowSpanPB" style="text-align:center; color:red">Hạng: <span class="numberinputInt">@(Math.Round(listXLTheoBoPhan[thuTuXL].thuHang ?? 0, 0, MidpointRounding.AwayFromZero))</span></td>
                                }
                            }
                            <td>@listXLTheoBoPhan[thuTuXL].tenPhongBan</td>
                            <td style="text-align: right">@listXLTheoBoPhan[thuTuXL].sL</td>
                            @{
                                var getSX = listTheoHangIndex.Where(t => t.thuTuHang == Convert.ToDouble(thuHangBanDau) && t.nam == @listXLTheoBoPhan[thuTuXL].nam).Select(m => new { m.phanTram, m.maLoai }).ToList();
                                if (getSX != null)
                                {
                                    double soLNVPB = listXLTheoBoPhan[thuTuXL].sL ?? 0;
                                    foreach (var itemSLMaLoai in getSX)
                                    {




                                        double giaTriTemp = Convert.ToDouble(itemSLMaLoai.phanTram * listXLTheoBoPhan[thuTuXL].sL / 100);
                                        double vlSoLuongTemp = Math.Round(giaTriTemp, 0, MidpointRounding.AwayFromZero);
                                        //Tinh tong
                                        totalSoLuongNVPB = totalSoLuongNVPB + vlSoLuongTemp;
                                        if (itemSLMaLoai.maLoai == "XS")
                                        {
                                            totalXuatSac = totalXuatSac + vlSoLuongTemp;
                                        }
                                        if (itemSLMaLoai.maLoai == "A+")
                                        {
                                            totalLoaiAA = totalLoaiAA + vlSoLuongTemp;
                                        }
                                        if (itemSLMaLoai.maLoai == "A")
                                        {
                                            totalLoaiA = totalLoaiA + vlSoLuongTemp;
                                        }
                                        if (itemSLMaLoai.maLoai == "B+")
                                        {
                                            totalLoaiBB = totalLoaiBB + vlSoLuongTemp;
                                        }
                                        if (itemSLMaLoai.maLoai == "B")
                                        {
                                            totalLoaiB = totalLoaiB + vlSoLuongTemp;
                                        }

                                        //End tinh tong
                                <td style="text-align: right">
                                    <input type="hidden" name="thuTuHangXLBP" value="@listXLTheoBoPhan[thuTuXL].thuHang" class="numberinputInt" />
                                    <input type="hidden" name="maPhongBanXLBP" value="@listXLTheoBoPhan[thuTuXL].maPhongBan" />
                                    <input type="hidden" name="maLoaiHangXLBP" value="@itemSLMaLoai.maLoai" />
                                    @{
                                        if (soLNVPB >= vlSoLuongTemp && itemSLMaLoai.maLoai != "C")
                                        {
                                            soLNVPB = soLNVPB - vlSoLuongTemp;
                                        <span>@vlSoLuongTemp</span>
                                        
                                       
                                        <input type="hidden" name="soLuongXLBP" value="@vlSoLuongTemp" />
                                        
                                        }
                                        else
                                        {

                                            if (soLNVPB <= 0) { soLNVPB = 0; }
                                        <input type="hidden" name="soLuongXLBP" value="@soLNVPB" />
                                        <span>@soLNVPB</span>
                                            if (itemSLMaLoai.maLoai == "C")
                                            {
                                                totalLoaiC = totalLoaiC + soLNVPB;
                                            }
                                            soLNVPB = 0;
                                        }
                                    }
                                </td>



                                    }
                                }
                            }


                        </tr>
                            }
                        }
                    }
                    <tr style="background-color: aliceblue; font-weight: bold">
                        <td colspan="2" style="text-align: center">Tổng cộng</td>
                        <td style="text-align: right">@(totalXuatSac + totalLoaiAA + totalLoaiA + totalLoaiBB + totalLoaiB + totalLoaiC)</td>
                        <td style="text-align: right">@totalXuatSac</td>
                        <td style="text-align: right">@totalLoaiAA</td>
                        <td style="text-align: right">@totalLoaiA</td>
                        <td style="text-align: right">@totalLoaiBB</td>
                        <td style="text-align: right">@totalLoaiB</td>
                        <td style="text-align: right">@totalLoaiC</td>
                    </tr>
                    <tr>
                        <td colspan="9" style="text-align: right">
                            <input type="button" class="btnAdd btnSaveXLTheoBP" value="Lưu" onclick="goSubmitXLBP()" /></td>
                    </tr>
                </tbody>

            </table>
        </div>
    </div>
</form>
<!-- End xep loai theo bo phan-->

