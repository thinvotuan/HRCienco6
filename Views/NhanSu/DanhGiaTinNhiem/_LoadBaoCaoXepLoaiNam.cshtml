@using BatDongSan.Models.NhanSu
@{
    ViewBag.Title = "Index";
    Layout = null;
    var listXL = ViewBag.listXLTong as List<BatDongSan.Models.DanhMuc.sp_DG_XepLoaiTongResult>;
    var listTheoHangIndex = ViewBag.lstTheoHangIndex as List<BatDongSan.Models.DanhMuc.sp_DG_XepLoaiTheoHang_IndexResult>;
    int total = (int)ViewBag.toTal;
    int totalHang = (int)ViewBag.totalHang;
    var listHangDist = listTheoHangIndex.Select(m => new { m.thuTuHang, m.soLuongNV }).Distinct().ToList();
    var countHang = listTheoHangIndex.Select(d => d.thuTuHang).Distinct().Count();

    // Xep loai theo bo phan
    var listXLTheoBoPhan = ViewBag.listXLTheoBoPhan as List<BatDongSan.Models.DanhMuc.sp_DG_XepLoaiTheoBoPhanResult>;
    var hangDistinceBoPhan = listXLTheoBoPhan.Select(m => new { m.thuHang }).Distinct();
    var countHangDistinceBoPhan = hangDistinceBoPhan.Count();
                                //End XLT BOPhan
    
 
}
<script type="text/javascript">
    $(document).ready(function () {
        $(".numberinput").autoNumeric('init', { mDec: 1, mNum: 3, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0' });
        $(".numberinputInt").autoNumeric('init', { mDec: 0, mNum: 3, lZero: 'deny', aSep: ',', aDec: '.', pSign: 's', vMin: '0' });
        $("#namThuHang,#namThuHangXLBP").val($("#nam").val());
        checkDuyetXL();

        $("#btnSaveSoLuong").click(function () {
            var imageUrl = '<div id="divMsg" align="center"><img src="/Content/Images/loading.gif "/></div>';

            $(".infor_MucLuongThuong").html(imageUrl).css('display', 'block');
            var lstMaLoai = "";
            var lstSoLuong = "";
            var arrSoLuong = [];
            var iSL = 0;
            var strString;
            //Get value
            jQuery("input[name='soLuong']").each(function (index, element) {
                strString = getNumber(jQuery(this).val());


                arrSoLuong[iSL] = strString;
                iSL++;
            });

            var arrMaLoai = [];
            var iML = 0;
            var strStringML;
            //Get value
            jQuery("input[name='maLoai']").each(function (index, element) {
                strStringML = jQuery(this).val();

                arrMaLoai[iML] = strStringML.split(',');
                iML++;
            });

            //post
            $.ajax({

                type: "POST",
                url: '/DanhGiaTinNhiem/UpdateMucLuongThuong',
                dataType: "json",
                data: { nam: $("#nam").val(), soLuongs: arrSoLuong.toString(), maLoais: arrMaLoai.toString() },
                success: function (result) {
                    $(".infor_MucLuongThuong").css('display', 'block');


                    $(".infor_MucLuongThuong").html('Cập nhật thành công mức lương thưởng năm:' + $("#nam").val());
                },
                error: function () {
                    $(".infor_MucLuongThuong").html('Cập nhật thất bại mức lương thưởng năm:' + $("#nam").val());

                }


            });
            //End post
        });
        $("#btnSaveTiLe").click(function () {
            var imageUrl = '<div id="divMsg" align="center"><img src="/Content/Images/loading.gif "/></div>';

            $(".infor_TiLe").html(imageUrl).css('display', 'block');
            var lstMaLoai = "";
            var lstSoLuong = "";
            var arrSoLuong = [];
            var iSL = 0;
            var strString;
            var tongTiLe = 0;
            //Get value
            jQuery("input[name='tiLe']").each(function (index, element) {
                strString = getNumber(jQuery(this).val());
                tongTiLe = tongTiLe + strString;
                arrSoLuong[iSL] = strString;

                iSL++;
            });
            if (tongTiLe > 100) {
                $(".infor_TiLe").html('Tổng tỉ lệ phải <= 100');
                return false;
            }
            var arrMaLoai = [];
            var iML = 0;
            var strStringML;
            //Get value
            jQuery("input[name='maLoai']").each(function (index, element) {
                strStringML = jQuery(this).val();

                arrMaLoai[iML] = strStringML.split(',');
                iML++;
            });

            //post
            $.ajax({

                type: "POST",
                url: '/DanhGiaTinNhiem/UpdateTiLe',
                dataType: "json",
                data: { nam: $("#nam").val(), tiLes: arrSoLuong.toString(), maLoais: arrMaLoai.toString() },
                success: function (result) {
                    $(".infor_TiLe").css('display', 'block');


                    $(".infor_TiLe").html('Cập nhật thành công tỉ lệ khen thưởng năm:' + $("#nam").val());
                },
                error: function () {
                    $(".infor_TiLe").html('Cập nhật thất bại tỉ lệ khen thưởng năm:' + $("#nam").val());

                }


            });
            //End post
        });
        $("#btnResetTiLeKT").click(function () {
            
            bootbox.confirm("Dữ liệu sẽ được đưa về trạng thái tạo mới?", function (result) {
                if (result) {
                    //post
                    $.ajax({

                        type: "POST",
                        url: '/DanhGiaTinNhiem/ResetTiLeKhenThuong',
                        dataType: "json",
                        data: { nam: $("#nam").val() },
                        success: function (result) {
                            
                            var url = '@Url.Action("LoadBaoCaoXepLoaiNam", "DanhGiaTinNhiem")' + "?nam=" + $("#nam").val();
                            var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
                            $('#tbody').html(imageUrl);

                            $('#tbody').load(url, function () {
                            });
                        },
                        error: function () {
                            $(".infor_TiLe").html('Khởi tạo thất bại năm:' + $("#nam").val());

                        }


                    });
                    //End post
                }
                
                
            });
        });
        $("input[name='tilephantram']").keyup(function () {

            var strStringTLPT = 0;
            var parentThuHang = $(this).parent().parent().attr('id');
            var idParent = "#" + parentThuHang + " input[name='tilephantram']";
            var total = 0;

            // Read ti le pt tat ca

            // End read
            // Tinh so luong
            var classParent = $(this).parent().attr('class');
            var clsParent = "." + classParent;

            var soLuongNV = clsParent + " input[name='soLuongNV']";
            var slNV = $(soLuongNV).val();
            var tiLePT = $(this).val();
            var soLuongHang = clsParent + " input[name='soLuongHang']";
            var giaTriSLHang = Math.round((slNV * tiLePT) / 100);
            $(soLuongHang).val(giaTriSLHang);
            checkSoLuong();
            // alert(index);
        });
        // So Luong change
        $("input[name='soLuongHang']").keyup(function () {

            //Tinh lai ti le %
            var classParent = $(this).parent().attr('class');
            var clsParent = "." + classParent;

            var soLuongNV = clsParent + " input[name='soLuongNV']";
            var slNV = $(soLuongNV).val();
            var slHang = $(this).val();
            var tiLePT = clsParent + " input[name='tilephantram']";

            var giaTriPT = (slHang * 100) / slNV;
            giaTriPT = giaTriPT.toFixed(2);
            $(tiLePT).val(giaTriPT);
            // End tinh lai ti le %
            //Check lai ti le %

            checkSoLuong();
        });
        //End so luong change


    });

    // Submit Form
    function goSubmit() {

        //  var imageUrl = '<div id="divMsg" align="center"><img src="/Content/Images/loading.gif "/></div>';

        // $(".infor_tiLeKhenThuongTheoXephang").html(imageUrl).css('display', 'block');
        $.post('@Url.Action("SaveKhenThuongTH")', ($('#frmCreate').serialize()), function (data) {

            //$(".infor_tiLeKhenThuongTheoXephang").html('Cập nhật thành công khen thưởng theo sếp hạn năm:' + $("#nam").val()).show();
            var url = '@Url.Action("LoadBaoCaoXepLoaiNam", "DanhGiaTinNhiem")' + "?nam=" + $("#nam").val();

            var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
            $('#tbody').html(imageUrl);
            $('#tbody').load(url, function () {
            });
        });
    }
        // Submit Form
        function goSubmitXLBP() {

            //  var imageUrl = '<div id="divMsg" align="center"><img src="/Content/Images/loading.gif "/></div>';

            // $(".infor_tiLeKhenThuongTheoXephang").html(imageUrl).css('display', 'block');
            $.post('@Url.Action("SaveXepLoaiTheoBP")', ($('#frmCreateXLBP').serialize()), function (data) {

                //$(".infor_tiLeKhenThuongTheoXephang").html('Cập nhật thành công khen thưởng theo sếp hạn năm:' + $("#nam").val()).show();
                var url = '@Url.Action("LoadBaoCaoXepLoaiNam", "DanhGiaTinNhiem")' + "?nam=" + $("#nam").val();

                var imageUrl = '<div id="divMsg" align="center"><img src="@Url.Content("~/Content/Images/loading.gif") "/></div>';
                $('#tbody').html(imageUrl);
                $('#tbody').load(url, function () {
                });
            });





        }
        function checkSoLuong() {
            var countThuHang = $(".parentThuHang").length;
            var checkFlashHang = 0;
            for (var j = 0; j < countThuHang; j++) {
                // Check all
                var idParent = "#parentThuHang_" + j + " input[name='soLuongHang']";
                var idParentHang = "#parentThuHang_" + j + " input[name='soLuongNV']";
                var total = 0;
                var slNVTheoHang = $(idParentHang).val();


                jQuery(idParent).each(function (index, element) {
                    strStringTLPT = getNumber(jQuery(this).val());
                    total = total + strStringTLPT;


                });

                if (total != slNVTheoHang) {
                    //alert("here");
                    $(".inforThuHang").eq(j).show();
                    $(".inforThuHang").eq(j).find(".inforSLHang").html("Số lượng theo loại phải bằng:" + slNVTheoHang + "<p>Giá trị hiện tại: " + total + "</p>");
                    // Alert.error("Số lượng phải bằng: " + slNVTheoHang + " (tổng số lượng NV)", "Thông báo", { displayDuration: 3000 });

                    $(".btnTiLeKTXH").hide();
                    checkFlashHang = 1;

                }
                else {
                    $(".inforThuHang").eq(j).hide();
                }

                // Check all
            }
            if (checkFlashHang == 1) {
                $(".btnTiLeKTXH").hide();
            }
            else {
                $(".btnTiLeKTXH").show();
                $(".inforThuHang").hide();
            }
        }




</script>
